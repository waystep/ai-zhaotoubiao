COMPOSE_PROJECT_NAME=ai-zhaotoubiao

# Public app endpoint. Replace APP_PORT with the port opened on the server.
APP_PORT=3000
AUTH_URL=http://124.220.97.19:3000
NEXT_PUBLIC_APP_URL=http://124.220.97.19:3000

# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-strong-random-secret

# PostgreSQL container credentials.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=smart_tender_review

# MinerU runs inside docker compose; this port is bound to 127.0.0.1 only.
MINERU_PORT=8000
MINERU_API_URL=http://mineru:8000
MINERU_API_KEY=
MINERU_TIMEOUT=300
MINERU_BACKEND=hybrid-auto-engine

# AI model key. Prefer ALIBABA_CODING_PLAN_API_KEY when using coding-plan-cn routes.
ALIBABA_API_KEY=
ALIBABA_CODING_PLAN_API_KEY=
DASHSCOPE_API_KEY=

# Optional services.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
REDIS_URL=
ENABLE_CRON_IN_DEV=false
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=smart-tender-review

